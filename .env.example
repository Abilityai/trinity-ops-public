# Trinity Instance Credentials
# Copy to .env and fill in your values
# chmod 600 .env

# ── Connection ──────────────────────────────────────────────
# Leave SSH_HOST empty to manage a local installation
SSH_HOST=                    # IP or hostname (empty = localhost)
SSH_USER=ubuntu              # SSH username
SSH_KEY=~/.ssh/id_rsa        # Path to private key
SSH_PASSWORD=                # Password auth (alternative to key; leave empty if using key)
SSH_PORT=22                  # SSH port (default: 22)

# ── Trinity on the server ────────────────────────────────────
TRINITY_PATH=/home/ubuntu/trinity
COMPOSE_FILE=docker-compose.prod.yml

# ── Service ports ────────────────────────────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8000
MCP_PORT=8180
SCHEDULER_PORT=8001

# ── Authentication ───────────────────────────────────────────
ADMIN_PASSWORD=              # Trinity admin login password (REQUIRED)
MCP_API_KEY=                 # MCP server API key

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # sk-ant-... (for agent containers)

# ── Local tunnel ports (when SSHing into a remote host) ──────
TUNNEL_FRONTEND=13000
TUNNEL_BACKEND=18000
TUNNEL_MCP=18180
